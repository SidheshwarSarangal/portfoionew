# Choose one content source: local, rest, or sanity.
VITE_CONTENT_PROVIDER="local"

# Exact public production URL, including a repository subpath when applicable.
# Used for the Vite production base, canonical URLs, sitemap entries, and social sharing.
VITE_SITE_URL="https://your-domain.com"

# Optional. Analytics remains completely disabled when this is blank.
VITE_GA_MEASUREMENT_ID=""

# Generic REST provider. The endpoint must return the canonical portfolio JSON shape.
VITE_CONTENT_API_URL="https://api.example.com/portfolio"

# Sanity provider. Only public, read-only identifiers belong in frontend variables.
VITE_SANITY_PROJECT_ID="your_project_id"
VITE_SANITY_DATASET="production"
VITE_SANITY_API_VERSION="2025-02-19"

# Never put database passwords, write tokens, or CMS management tokens in VITE_* variables.
